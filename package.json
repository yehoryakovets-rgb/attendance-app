{
  "name": "attendance-manager",
  "version": "1.1.7",
  "description": "Attendance Manager for classroom use",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.attendance.manager",
    "productName": "Attendance Manager",
    "mac": {
      "category": "public.app-category.education",
      "icon": "assets/icon.png",
      "target": [
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "fileAssociations": [
      {
        "ext": "am",
        "name": "Attendance Class",
        "role": "Editor",
        "rank": "Owner"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
